# Password for /admin sign-in. Defaults to "admin123" if unset.
ADMIN_PASSWORD=change-me-please

# --- Supabase (set in Vercel project Settings → Environment Variables too) ---
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- MyFatoorah payment gateway (Phase 1: client lib only — UI not wired yet) ---
# Get an API token from the test portal: https://portal.myfatoorah.com
# When this is unset the app falls back to the existing fake-gateway demo.
MYFATOORAH_API_TOKEN=
# Test: https://apitest.myfatoorah.com   Live: https://api.myfatoorah.com
MYFATOORAH_BASE_URL=https://apitest.myfatoorah.com
# Public base URL where the gateway redirects after payment.
# Locally:  http://localhost:3000
# Vercel:   https://joe-barber-studio.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Optional overrides; defaults derive from NEXT_PUBLIC_BASE_URL.
# MYFATOORAH_CALLBACK_URL=https://joe-barber-studio.vercel.app/api/payment/callback
# MYFATOORAH_ERROR_URL=https://joe-barber-studio.vercel.app/api/payment/callback?status=error

# --- Twilio (SMS reminders) — optional, app no-ops if unset ---
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 phone number bought from Twilio (e.g. +12015551234)
TWILIO_FROM_NUMBER=

# --- Resend (email reminders) — optional, app no-ops if unset ---
# Get from https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender address, e.g. bookings@yourshop.com
RESEND_FROM=
